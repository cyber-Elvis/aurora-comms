# SSH config for the Nornir/Netmiko mini-lab — jump through the GNS3 bastion to
# the Region A IOS-XRv management network. The ProxyCommand uses the openssh
# binary (key auth to gns3); the node hop is negotiated by paramiko/Netmiko.
Host 10.255.191.*
    ProxyCommand ssh -o BatchMode=yes -W %h:%p gns3@100.118.0.46
    PubkeyAuthentication no
    StrictHostKeyChecking accept-new
    UserKnownHostsFile ~/.ssh/aurora_iosxr_known_hosts
