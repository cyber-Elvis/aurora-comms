        <mxCell id="policy-note" value="Route policy intent&lt;br&gt;&lt;b&gt;IXP LP300 &amp;gt; Transit-A LP200 &amp;gt; Transit-B LP100&lt;/b&gt;&lt;br&gt;Advertise outward only Aurora PI 203.0.113.0/25, 2001:db8:aaaa::/48, and approved customer aggregates.&lt;br&gt;Drop RPKI Invalid at edge; NotFound accepted. No transit routes to IXP; no IXP routes to transit except labelled leak demo." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#047857;fontColor=#064e3b;fontSize=12;align=left;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="1405" y="795" width="700" height="125" as="geometry" />
        </mxCell>
        <mxCell id="vprn-note" value="VPRN convention&lt;br&gt;RD = 64496:&amp;lt;customer_id&amp;gt;&lt;br&gt;RT = target:64496:&amp;lt;customer_id&amp;gt;&lt;br&gt;Helix ID 2 | Northwind ID 3 | Maple Ridge ID 1 reserved&lt;br&gt;&lt;br&gt;RR note: no RR in v1.2; introduce when Region A &amp;gt; 5 PEs or Region B integration begins." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#1e3a8a;fontSize=11;align=left;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="1405" y="935" width="340" height="130" as="geometry" />
        </mxCell>
        <mxCell id="legend" value="Legend&lt;br&gt;&lt;font color=&quot;#0f172a&quot;&gt;Solid line: physical/L3 adjacency&lt;br&gt;Dashed line: overlay/control-plane session&lt;br&gt;Dotted line: optional/future path&lt;br&gt;Purple: transit | Teal: IXP/FRR | Grey: mgmt/RPKI&lt;br&gt;Red: Fortinet | Orange: Aruba | Yellow: workloads&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#94a3b8;fontColor=#0f172a;fontSize=11;align=left;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="1765" y="935" width="340" height="130" as="geometry" />
        </mxCell>
        <mxCell id="guardrail" value="Guardrail: this is a behavioural lab model only. ASNs 64496-64502 are RFC 5398 documentation ASNs; IPv4 is RFC 5737 documentation space and IPv6 is RFC 3849 documentation space. Nothing here is commercial public Internet or registered RIR RPKI." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff1f2;strokeColor=#be123c;fontColor=#881337;fontSize=12;fontStyle=1;align=left;spacing=8;" vertex="1" parent="1">
